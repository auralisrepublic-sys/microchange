{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balances",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "alias": { "type": "string", "description": "MCROXXXXXXXXX format" },
        "balances": {
          "type": "object",
          "properties": {
            "CAURA": { "type": "number" },
            "FARISTEL": { "type": "number" },
            "SOLARIS": { "type": "number" },
            "UNITED_LAND_KING": { "type": "number" }
          }
        },
        "preferredCurrency": { "type": "string", "enum": ["CAURA", "FARISTEL", "SOLARIS", "UNITED_LAND_KING", "CHESSAR", "NEW_GREENIAN_CROWN", "ECLAT"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "alias", "balances"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Token transfer or exchange",
      "type": "object",
      "properties": {
        "fromUid": { "type": "string" },
        "toUid": { "type": "string" },
        "fromAlias": { "type": "string" },
        "toAlias": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["transfer", "exchange", "reserve_deposit", "reserve_withdraw", "purchase"] },
        "productId": { "type": "string" },
        "productName": { "type": "string" }
      },
      "required": ["amount", "currency", "timestamp", "type"]
    },
    "Reserve": {
      "title": "Reserve",
      "description": "Money reserve/vault for saving",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "currency": { "type": "string" },
        "balance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "currency", "balance", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Item for sale in MicroShop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "sellerUid": { "type": "string" },
        "sellerAlias": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "currency", "sellerUid", "sellerAlias", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/reserves/{reserveId}": {
      "schema": "Reserve",
      "description": "User's money reserves"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction history"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Marketplace products"
    },
    "/aliases/{alias}": {
      "schema": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" }
        }
      },
      "description": "Alias to UID mapping for quick lookup"
    },
    "/settings/currencies": {
      "schema": {
        "type": "object",
        "properties": {
          "UNITED_LAND_KING_rate": { "type": "number" }
        }
      },
      "description": "Dynamic currency rates"
    }
  }
}
