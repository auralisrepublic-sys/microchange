rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated() && (request.auth.token.email == "mainosalvi@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - uid: string (required, immutable)
    //   - email: string (required, immutable)
    //   - displayName: string (required)
    //   - alias: string (required, immutable, unique)
    //   - balances: map (required)
    //   - preferredCurrency: string (required)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - fromUid: string (required)
    //   - toUid: string (required)
    //   - fromAlias: string (required)
    //   - toAlias: string (required)
    //   - amount: number (required, positive)
    //   - currency: string (required)
    //   - timestamp: timestamp (required)
    //   - type: string (required, ['transfer', 'exchange'])
    //
    // Collection: aliases
    // Document ID: {alias} (MCROXXXXXXXXX)
    // Fields:
    //   - uid: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "auralisrepublic@gmail.com" && request.auth.token.email_verified == true) ||
         (request.auth.token.email == "mainosalvi@gmail.com" && request.auth.token.email_verified == true));
    }

    function isCurrencyAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "mainosalvi@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'alias', 'balances', 'preferredCurrency', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.alias is string && data.alias.matches("^MCRO[A-Z0-9]{9}$") &&
             data.balances is map &&
             data.preferredCurrency in ['CAURA', 'FARISTEL', 'SOLARIS', 'UNITED_LAND_KING', 'CHESSAR', 'NEW_GREENIAN_CROWN', 'OURS_IS_ECLAT'] &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (
        (isOwner(userId) && isValidUser(request.resource.data) &&
         request.resource.data.uid == resource.data.uid &&
         request.resource.data.email == resource.data.email &&
         request.resource.data.alias == resource.data.alias &&
         request.resource.data.createdAt == resource.data.createdAt) ||
        (!isOwner(userId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balances']) &&
         isValidUser(request.resource.data))
      );
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if isAuthenticated() && 
                    request.resource.data.fromUid == request.auth.uid &&
                    request.resource.data.amount > 0;
    }

    match /aliases/{alias} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }
  }
}
