rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated() && (request.auth.token.email == "mainosalvi@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - uid: string (required, immutable)
    //   - email: string (required, immutable)
    //   - displayName: string (required)
    //   - alias: string (required, immutable, unique)
    //   - balances: map (required)
    //   - preferredCurrency: string (required)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - fromUid: string (required)
    //   - toUid: string (required)
    //   - fromAlias: string (required)
    //   - toAlias: string (required)
    //   - amount: number (required, positive)
    //   - currency: string (required)
    //   - timestamp: timestamp (required)
    //   - type: string (required, ['transfer', 'exchange', 'reserve_deposit', 'reserve_withdraw'])
    //   - reserveId: string (optional)
    //   - reserveName: string (optional)
    //
    // Collection: users/{userId}/reserves
    // Document ID: {reserveId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - currency: string (required)
    //   - balance: number (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: aliases
    // Document ID: {alias} (MCROXXXXXXXXX)
    // Fields:
    //   - uid: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "auralisrepublic@gmail.com" && request.auth.token.email_verified == true) ||
         (request.auth.token.email == "mainosalvi@gmail.com" && request.auth.token.email_verified == true));
    }

    function isCurrencyAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "mainosalvi@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'alias', 'balances', 'preferredCurrency', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.alias is string && data.alias.matches("^MCRO[A-Z0-9]{9}$") &&
             data.balances is map &&
             data.preferredCurrency in ['CAURA', 'FARISTEL', 'SOLARIS', 'UNITED_LAND_KING', 'CHESSAR', 'NEW_GREENIAN_CROWN', 'ECLAT'] &&
             data.createdAt is timestamp;
    }

    function isValidReserve(data, reserveId) {
      return data.keys().hasAll(['id', 'name', 'currency', 'balance', 'createdAt']) &&
             data.id == reserveId &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.currency in ['CAURA', 'FARISTEL', 'SOLARIS', 'UNITED_LAND_KING', 'CHESSAR', 'NEW_GREENIAN_CROWN', 'ECLAT'] &&
             data.balance is number && data.balance >= 0 &&
             (data.createdAt == request.time || data.createdAt is timestamp);
    }

    function isValidProduct(data, productId) {
      return data.keys().hasAll(['id', 'name', 'price', 'currency', 'sellerUid', 'sellerAlias', 'createdAt']) &&
             data.id == productId &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() < 1000 &&
             data.price is number && data.price > 0 &&
             data.currency in ['CAURA', 'FARISTEL', 'SOLARIS', 'UNITED_LAND_KING', 'CHESSAR', 'NEW_GREENIAN_CROWN', 'ECLAT'] &&
             data.sellerUid == request.auth.uid &&
             (data.createdAt == request.time || data.createdAt is timestamp);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (
        (isOwner(userId) && isValidUser(request.resource.data) &&
         request.resource.data.uid == resource.data.uid &&
         request.resource.data.email == resource.data.email &&
         request.resource.data.alias == resource.data.alias &&
         request.resource.data.createdAt == resource.data.createdAt) ||
        (!isOwner(userId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balances']) &&
         isValidUser(request.resource.data))
      );

      match /reserves/{reserveId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidReserve(request.resource.data, reserveId);
        allow update: if isOwner(userId) && isValidReserve(request.resource.data, reserveId) &&
                      request.resource.data.id == resource.data.id &&
                      request.resource.data.currency == resource.data.currency &&
                      request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId);
      }
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if isAuthenticated() && 
                    request.resource.data.fromUid == request.auth.uid &&
                    request.resource.data.amount > 0 &&
                    request.resource.data.type in ['transfer', 'exchange', 'reserve_deposit', 'reserve_withdraw', 'purchase'];
    }

    match /products/{productId} {
      allow read, list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProduct(request.resource.data, productId);
      allow update: if isAuthenticated() && (
        (resource.data.sellerUid == request.auth.uid && isValidProduct(request.resource.data, productId)) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['id', 'name', 'description', 'price', 'currency', 'sellerUid', 'sellerAlias', 'createdAt']))
      );
      allow delete: if isAuthenticated() && resource.data.sellerUid == request.auth.uid;
    }

    match /aliases/{alias} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }
  }
}
